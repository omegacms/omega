class SqliteMigration extends AbstractMigration
{
    /**
     * Sqlite object.
     *
     * @var SqliteAdapter $connection Holds an instance of Sqlite.
     */
    public SqliteAdapter $connection;

    /**
     * MysqlMigration class constructor.

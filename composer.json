{
  "name": "omegacms/omega",
  "type": "project",
  "description": "The example application for the Omega framework.",
  "homepage": "https://omegacms.github.io",
  "license": "GPL-3.0",
  "authors": [
    {
      "name": "Adriano Giovannini",
      "email": "omegacms@outlook.com",
      "role": "Developer"
    }
  ],
  "keywords": [
    "omegacms",
    "framework"
  ],
  "require": {
    "php": ">=8.2",
    "composer/composer": "2.*",
    "league/flysystem": "^3.12",
    "omegacms/framework": "^1.0.0",
    "symfony/console": "^5.1",
    "vlucas/phpdotenv": "^5.2",
    "phpoption/phpoption": "^1.9"
  },
  "require-dev": {
    "filp/whoops": "^2.15",
    "monolog/monolog": "^3.3",
    "omegacms/testing": "^1.0.0",
    "phpstan/phpstan": "^1.10",
    "phpunit/phpunit": "^9.5",
    "symfony/panther": "^2.1",
    "symfony/process": "^5.2",
    "dbrekelmans/bdi": "^1.3"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "serve": "php omega serve",
    "dbmigrate": "php omega migrate",
    "dbfresh": "php omega migrate --fresh",
    "test": "vendor/bin/phpunit --verbose",
    "post-update-cmd": [
      "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ]
  },
  "config": {
    "process-timeout": 500,
    "optimize-autoloader": false,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
